{
  "outputDirectory": "public",
  "devCommand": null,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/app",          "destination": "/app.html" },
    { "source": "/painel-team",  "destination": "/painel-team.html" },
    { "source": "/historico",    "destination": "/historico.html" },
    { "source": "/admin",        "destination": "/admin.html" },
    { "source": "/",             "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/focus?action=cron-weekly-snapshot",
      "schedule": "0 2 * * 6"
    },
    {
      "path": "/api/routines?action=alarm-check",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/focus?action=cron-daily-notify",
      "schedule": "0 12 * * 1-5"
    }
  ]
}
